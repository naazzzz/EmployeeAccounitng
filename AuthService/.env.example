##Broker messages
###RabbitMq
BROKER_TYPE=RabbitMQ
BROKER_HOST=localhost

## App
APP_PORT=8082
APP_VERSION=0.0.1.0
ASPNETCORE_URLS=https://localhost:${APP_PORT}
ASPNETCORE_ENVIRONMENT=Development

## Databases
###Pgsql
POSTGRES_DB=app_auth
POSTGRES_PASSWORD=!ChangeMe!
POSTGRES_USER=app
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_CONNECTION_STRING=Server=${POSTGRES_HOST}; Port=${POSTGRES_PORT}; Database=${POSTGRES_DB}; Username=${POSTGRES_USER}; Password=${POSTGRES_PASSWORD}

## OAuth
OAUTH_CLIENT_ID=id
OAUTH_CLIENT_SECRET=secret
JWT_TOKEN_SECRET=your-secure-secret-key-at-least-32-chars
JWT_AUD_ISS_CLAIM=myapp

## Services
AUTH_SERVICE_PATH=https://localhost:7197